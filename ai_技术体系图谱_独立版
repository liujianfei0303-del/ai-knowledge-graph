<title>AI 技术体系知识图谱 — 交互式</title>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Noto Sans SC', sans-serif; background: #1a1a2e; color: #e0e0e0; overflow: hidden; height: 100vh; }
#container { width: 100%; height: 100vh; position: relative; }
svg { width: 100%; height: 100%; display: block; }
.legend { position: absolute; top: 20px; left: 20px; background: rgba(26,26,46,0.92); padding: 16px 20px; border-radius: 12px; font-size: 13px; border: 1px solid rgba(255,255,255,0.08); backdrop-filter: blur(8px); z-index: 10; max-height: 80vh; overflow-y: auto; }
.legend h3 { font-size: 14px; margin-bottom: 10px; color: #a0a0c0; font-weight: 500; }
.legend-item { display: flex; align-items: center; gap: 10px; margin: 4px 0; cursor: pointer; padding: 2px 6px; border-radius: 4px; transition: background 0.2s; }
.legend-item:hover { background: rgba(255,255,255,0.05); }
.legend-color { width: 14px; height: 14px; border-radius: 50%; flex-shrink: 0; }
.legend-label { font-size: 12px; color: #c0c0d0; }
.legend-count { font-size: 11px; color: #707090; margin-left: auto; }
.tooltip { position: absolute; display: none; background: rgba(26,26,46,0.95); padding: 14px 18px; border-radius: 12px; font-size: 13px; border: 1px solid rgba(255,255,255,0.12); pointer-events: none; max-width: 340px; z-index: 100; box-shadow: 0 8px 32px rgba(0,0,0,0.4); }
.tooltip .title { color: #e0e0ff; font-weight: 600; font-size: 15px; }
.tooltip .meta { color: #8888aa; font-size: 11px; margin-top: 4px; }
.tooltip .desc { color: #b0b0c8; font-size: 12px; margin-top: 8px; line-height: 1.6; }
.tooltip .links { color: #66aaff; font-size: 11px; margin-top: 6px; }
.controls { position: absolute; bottom: 24px; left: 50%; transform: translateX(-50%); background: rgba(26,26,46,0.88); padding: 10px 20px; border-radius: 24px; font-size: 12px; color: #8080a0; border: 1px solid rgba(255,255,255,0.06); backdrop-filter: blur(8px); display: flex; gap: 16px; align-items: center; z-index: 10; }
.controls button { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); color: #c0c0e0; padding: 4px 12px; border-radius: 12px; cursor: pointer; font-size: 12px; transition: all 0.2s; }
.controls button:hover { background: rgba(255,255,255,0.12); }
.node { cursor: pointer; transition: opacity 0.1s; }
.node:hover { filter: brightness(1.3); }
.link { stroke-opacity: 0.3; }
.node-label { font-size: 10px; pointer-events: none; text-shadow: 0 1px 3px rgba(0,0,0,0.9); }
.loading { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); text-align: center; }
.loading .spinner { width: 40px; height: 40px; border: 3px solid rgba(255,255,255,0.1); border-top-color: #66aaff; border-radius: 50%; animation: spin 1s linear infinite; margin: 0 auto 16px; }
@keyframes spin { to { transform: rotate(360deg); } }
.loading p { color: #8080a0; font-size: 14px; }
.search-box { position: absolute; top: 20px; right: 20px; z-index: 10; }
.search-box input { background: rgba(26,26,46,0.9); border: 1px solid rgba(255,255,255,0.1); color: #e0e0e0; padding: 8px 14px; border-radius: 20px; font-size: 13px; width: 180px; backdrop-filter: blur(8px); outline: none; }
.search-box input:focus { border-color: #66aaff; }
.search-box input::placeholder { color: #606080; }
.detail-panel { position: absolute; right: -360px; top: 0; width: 340px; height: 100vh; background: rgba(26,26,46,0.96); border-left: 1px solid rgba(255,255,255,0.06); padding: 20px; overflow-y: auto; transition: right 0.3s; z-index: 20; backdrop-filter: blur(12px); }
.detail-panel.open { right: 0; }
.detail-panel .close { float: right; cursor: pointer; color: #606080; font-size: 20px; line-height: 1; }
.detail-panel .close:hover { color: #c0c0e0; }
.detail-panel .d-title { font-size: 18px; color: #f0f0ff; font-weight: 600; margin-bottom: 8px; padding-right: 24px; }
.detail-panel .d-meta { font-size: 12px; color: #8080a0; margin-bottom: 12px; }
.detail-panel .d-desc { font-size: 13px; color: #c0c0d0; line-height: 1.8; }
.detail-panel .d-links { margin-top: 16px; padding-top: 12px; border-top: 1px solid rgba(255,255,255,0.06); font-size: 12px; color: #66aaff; }
.detail-panel .d-links span { display: block; padding: 2px 0; color: #c0c0d0; }
@media (max-width: 700px) { .detail-panel { width: 280px; right: -300px; } .legend { font-size: 11px; padding: 10px 14px; } .search-box input { width: 120px; } }
</style>
