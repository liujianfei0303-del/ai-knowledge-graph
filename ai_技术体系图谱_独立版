a"}, {"source": "横切B-AI系统属性/LIME", "target": "横切B-AI系统属性/SHAP"}, {"source": "横切B-AI系统属性/SHAP", "target": "Layer-3-化工与过程控制/数据驱动FDD"}, {"source": "横切B-AI系统属性/SHAP", "target": "横切A-数据驱动方法论/DAG因果图"}, {"source": "横切B-AI系统属性/对抗样本", "target": "横切B-AI系统属性/Prompt注入"}, {"source": "横切B-AI系统属性/激活工程", "target": "横切B-AI系统属性/稀疏自编码器"}, {"source": "横切B-AI系统属性/稀疏自编码器", "target": "横切B-AI系统属性/激活工程"}];
var LAYER_ORDER = ["数学基础", "数据工程", "经典机器学习", "深度学习 & Transformer", "强化学习", "化工与过程控制", "Agent 生态", "MLOps", "横切 A：数据驱动方法论", "横切 B：AI 系统属性"];
var LAYER_COLORS = {"数学基础": "#4a9eff", "数据工程": "#22c55e", "经典机器学习": "#f59e0b", "深度学习 & Transformer": "#ef4444", "强化学习": "#a855f7", "化工与过程控制": "#06b6d4", "Agent 生态": "#ec4899", "MLOps": "#14b8a6", "横切 A：数据驱动方法论": "#f97316", "横切 B：AI 系统属性": "#8b5cf6"};
var TYPE_NAMES = {"concept": "概念", "algorithm": "算法", "framework": "框架", "tool": "工具", "technique": "技术", "method": "方法", "standard": "标准"};
var graphData = { nodes: NODES, links: LINKS };
function initGraph() {
var container = document.getElementById('container');
var w = window.innerWidth, h = window.innerHeight;
d3.select('#container svg').remove();
var svg = d3.select('#container').insert('svg',':first-child').attr('width',w).attr('height',h);
var g = svg.append('g');
var tip = d3.select('#tooltip');
var zoom = d3.zoom().scaleExtent([0.2,4]).on('zoom',e=>g.attr('transform',e.transform));
svg.call(zoom); render(graphData,svg,g,tip,w,h,zoom);
}
function render(graph,svg,g,tip,w,h,zoom) {
d3.select('#loading').remove();
document.getElementById('nodeCount').textContent=graph.nodes.length+' 节点';
document.getElementById('linkCount').textContent=graph.links.length+' 连接';
var sim = d3.forceSimulation(graph.nodes)
.force('link',d3.forceLink(graph.links).id(d=>d.id).distance(80).strength(0.3))
.force('charge',d3.forceManyBody().strength(-180))
.force('center',d3.forceCenter(w/2,h/2))
.force('collision',d3.forceCollide().radius(20));
var link=g.append('g').selectAll('line').data(graph.links).join('line').attr('class','link').attr('stroke','#606080').attr('stroke-width',0.8);
var node=g.append('g').selectAll('g').data(graph.nodes).join('g').attr('class','node');
node.each(function(d){var e=d3.select(this),c=LAYER_COLORS[d.layerDisplay]||'#666688',s=d.tier===1?10:8;e.append('circle').attr('r',s).attr('fill',c).attr('stroke','rgba(255,255,255,0.15)').attr('stroke-width',1);});
var lbl=g.append('g').selectAll('text').data(graph.nodes).join('text').attr('class','node-label').attr('fill','#d0d0e0').attr('dy',d=>d.tier===1?20:16).attr('text-anchor','middle').text(d=>d.title).style('display',d=>d.tier===1?'block':'none');
node.on('mouseover',function(ev,d){
var s=new Set();graph.links.forEach(function(l){var a=typeof l.source==='object'?l.source.id:l.source,b=typeof l.target==='object'?l.target.id:l.target;if(a===d.id||b===d.id){s.add(a);s.add(b);}});
node.style('opacity',n=>s.has(n.id)||n.id===d.id?1:0.15);
link.style('opacity',l=>{var a=typeof l.source==='object'?l.source.id:l.source,b=typeof l.target==='object'?l.target.id:l.target;return a===d.id||b===d.id?0.6:0.08;});
lbl.style('display',n=>s.has(n.id)||n.id===d.id?'block':'none');
var cl=graph.links.filter(l=>{var a=typeof l.source==='object'?l.source.id:l.source,b=typeof l.target==='object'?l.target.id:l.target;return a===d.id||b===d.id;});
var ot=cl.map(l=>{var a=typeof l.source==='object'?l.source.id:l.source;return a===d.id?graph.nodes.find(n=>n.id===l.target.id):graph.nodes.find(n=>n.id===l.source.id);}).filter(t=>t).map(t=>t.title).filter(t=>t!==d.title).join(' · ');
tip.style('display','block').style('left',(ev.clientX-container.getBoundingClientRect().left+14)+'px').style('top',(ev.clientY-container.getBoundingClientRect().top-10)+'px').html('<div class="title">'+d.title+'</div><div class="meta">'+d.layerDisplay+' · '+(TYPE_NAMES[d.type]||d.type)+(d.tier?' · Tier '+d.tier:'')+'</div>'+(d.desc?'<div class="desc">'+d.desc+'</div>':'')+(cl.length>0?'<div class="links">关联 '+cl.length+' 个节点</div>':''));
});
node.on('mouseout',function(){node.style('opacity',1);link.style('opacity',0.3);tip.style('display','none');lbl.style('display',d=>d.tier===1?'block':'none');});
node.on('click',function(ev,d){openPanel(d);});
var lh='<h3>按层着色</h3>';LAYER_ORDER.forEach(function(l){var c=graph.nodes.filter(function(n){return n.layerDisplay===l;}).length;if(c>0){lh+='<div class=\"legend-item\" onclick=\"filterLayer(\''+l.replace(/'/g,"\\'")+'\')\"><span class=\"legend-color\" style=\"background:'+(LAYER_COLORS[l]||'#666688')+'\"></span><span class=\"legend-label\">'+l+'</span><span class=\"legend-count\">'+c+'</span></div>';}});
document.getElementById('legend').innerHTML=lh;
sim.on('tick',function(){link.attr('x1',d=>d.source.x).attr('y1',d=>d.source.y).attr('x2',d=>d.target.x).attr('y2',d=>d.target.y);node.attr('transform',d=>'translate('+d.x+','+d.y+')');lbl.attr('x',d=>d.x).attr('y',d=>d.y);});
}
function openPanel(d){
document.getElementById('dTitle').textContent=d.title;
document.getElementById('dMeta').textContent=(TYPE_NAMES[d.type]||d.type)+' · '+d.layerDisplay+' · Tier '+(d.tier||2);
document.getElementById('dDesc').textContent=d.desc||'暂无详细描述';
var cl=graphData.links.filter(function(l){var a=typeof l.source==='object'?l.source.id:l.source,b=typeof l.target==='object'?l.target.id:l.target;return a===d.id||b===d.id;});
var ot=cl.map(function(l){var a=typeof l.source==='object'?l.source.id:l.source,b=typeof l.target==='object'?l.target.id:l.target;return a===d.id?graphData.nodes.find(n=>n.id===b):graphData.nodes.find(n=>n.id===a);}).filter(t=>t&&t.title!==d.title).map(t=>t.title);
document.getElementById('dLinks').innerHTML=ot.length?'<strong>关联节点：</strong><br>'+ot.map(t=>'<span>→ '+t+'</span>').join(''):'<span>无关联节点</span>';
document.getElementById('detailPanel').classList.add('open');
}
function closePanel(){document.getElementById('detailPanel').classList.remove('open');}
function resetZoom(){d3.select('svg').transition().duration(500).call(d3.zoom().transform,d3.zoomIdentity);}
var currentFilter=null;
function filterLayer(layer){
if(currentFilter===layer){currentFilter=null;d3.selectAll('.node').style('opacity',1);d3.selectAll('.link').style('opacity',0.3);d3.selectAll('.node-label').style('display',d=>d.tier===1?'block':'none');}
else{currentFilter=layer;d3.selectAll('.node').style('opacity',d=>d.layerDisplay===layer?1:0.1);d3.selectAll('.link').style('opacity',l=>l.source.layerDisplay===layer&&l.target.layerDisplay===layer?0.5:0.04);d3.selectAll('.node-label').style('display',d=>d.layerDisplay===layer?'block':'none');}
}
function searchNodes(q){
if(!q){d3.selectAll('.node').style('opacity',1);d3.selectAll('.link').style('opacity',0.3);return;}
var m=new Set();graphData.nodes.forEach(function(n){if(n.title.toLowerCase().includes(q.toLowerCase())||n.desc.toLowerCase().includes(q.toLowerCase()))m.add(n.id);});
d3.selectAll('.node').style('opacity',d=>m.has(d.id)?1:0.08);
d3.selectAll('.link').style('opacity',l=>{var a=typeof l.source==='object'?l.source.id:l.source,b=typeof l.target==='object'?l.target.id:l.target;return m.has(a)&&m.has(b)?0.5:0.03;});
}
document.addEventListener('DOMContentLoaded',initGraph);
window.addEventListener('pageshow',initGraph);
window.addEventListener('resize',function(){location.reload();});
</script>
