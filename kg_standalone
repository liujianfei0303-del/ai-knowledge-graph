    var link=g.append('g').selectAll('line').data(graph.links).join('line').attr('class','link').attr('stroke','#606080').attr('stroke-width',0.8);
    var node=g.append('g').selectAll('g').data(graph.nodes).join('g').attr('class','node');
    node.each(function(d){var e=d3.select(this),c=LAYER_COLORS[d.layerDisplay]||'#666688',s=d.tier===1?10:8;e.append('circle').attr('r',s).attr('fill',c).attr('stroke','rgba(255,255,255,0.15)').attr('stroke-width',1);});
    var lbl=g.append('g').selectAll('text').data(graph.nodes).join('text').attr('class','node-label').attr('fill','#d0d0e0').attr('dy',function(d){return d.tier===1?20:16;}).attr('text-anchor','middle').text(function(d){return d.title;}).style('display',function(d){return d.tier===1?'block':'none';});
    node.on('mouseover',function(ev,d){
        var s=new Set();graph.links.forEach(function(l){var a=typeof l.source==='object'?l.source.id:l.source,b=typeof l.target==='object'?l.target.id:l.target;if(a===d.id||b===d.id){s.add(a);s.add(b);}});
        node.style('opacity',function(n){return s.has(n.id)||n.id===d.id?1:0.15;});
        link.style('opacity',function(l){var a=typeof l.source==='object'?l.source.id:l.source,b=typeof l.target==='object'?l.target.id:l.target;return a===d.id||b===d.id?0.6:0.08;});
        lbl.style('display',function(n){return s.has(n.id)||n.id===d.id?'block':'none';});
        var cl=graph.links.filter(function(l){var a=typeof l.source==='object'?l.source.id:l.source,b=typeof l.target==='object'?l.target.id:l.target;return a===d.id||b===d.id;});
        var tipHtml='<div class="title">'+d.title+'</div><div class="meta">'+d.layerDisplay+' · '+(TYPE_NAMES[d.type]||d.type)+(d.tier?' · Tier '+d.tier:'')+'</div>';
        if(d.desc){tipHtml+='<div class="desc">'+d.desc.substring(0,200)+'</div>';}
        if(cl.length>0){tipHtml+='<div class="links">关联 '+cl.length+' 个节点</div>';}
        tip.style('display','block').style('left',(ev.clientX-graphView.getBoundingClientRect().left+14)+'px').style('top',(ev.clientY-graphView.getBoundingClientRect().top-10)+'px').html(tipHtml);
    });
    node.on('mouseout',function(){node.style('opacity',1);link.style('opacity',0.3);tip.style('display','none');lbl.style('display',function(d){return d.tier===1?'block':'none';});});
    node.on('click',function(ev,d){openPanel(d);});
    var lh='<h3>按层着色</h3>';
    LAYER_ORDER.forEach(function(l){
        var c=graph.nodes.filter(function(n){return n.layerDisplay===l;}).length;
        if(c>0){lh+='<div class="legend-item" onclick="filterLayer(\''+l.replace(/'/g,"\\'")+'\')"><span class="legend-color" style="background:'+(LAYER_COLORS[l]||"#666688")+'"></span><span class="legend-label">'+l+'</span><span class="legend-count">'+c+'</span></div>';}
    });
    document.getElementById('legend').innerHTML=lh;
    sim.on('tick',function(){link.attr('x1',function(d){return d.source.x;}).attr('y1',function(d){return d.source.y;}).attr('x2',function(d){return d.target.x;}).attr('y2',function(d){return d.target.y;});node.attr('transform',function(d){return 'translate('+d.x+','+d.y+')';});lbl.attr('x',function(d){return d.x;}).attr('y',function(d){return d.y;});});
}
var currentFilter=null;
function filterLayer(layer){
    if(currentFilter===layer){currentFilter=null;d3.selectAll('.node').style('opacity',1);d3.selectAll('.link').style('opacity',0.3);d3.selectAll('.node-label').style('display',function(d){return d.tier===1?'block':'none';});}
    else{currentFilter=layer;d3.selectAll('.node').style('opacity',function(d){return d.layerDisplay===layer?1:0.1;});d3.selectAll('.link').style('opacity',function(l){return l.source.layerDisplay===layer&&l.target.layerDisplay===layer?0.5:0.04;});d3.selectAll('.node-label').style('display',function(d){return d.layerDisplay===layer?'block':'none';});}
}
function searchNodes(q){
    if(!q){d3.selectAll('.node').style('opacity',1);d3.selectAll('.link').style('opacity',0.3);return;}
    var m=new Set();graphData.nodes.forEach(function(n){if(n.title.toLowerCase().includes(q.toLowerCase())||(n.desc||'').toLowerCase().includes(q.toLowerCase()))m.add(n.id);});
    d3.selectAll('.node').style('opacity',function(d){return m.has(d.id)?1:0.08;});
    d3.selectAll('.link').style('opacity',function(l){var a=typeof l.source==='object'?l.source.id:l.source,b=typeof l.target==='object'?l.target.id:l.target;return m.has(a)&&m.has(b)?0.5:0.03;});
}
function openPanel(d){
    document.getElementById('dTitle').textContent=d.title;
    document.getElementById('dMeta').textContent=(TYPE_NAMES[d.type]||d.type)+' · '+d.layerDisplay+' · Tier '+(d.tier||2);
    document.getElementById('dDesc').textContent=d.desc||'暂无详细描述';
    var cl=graphData.links.filter(function(l){var a=typeof l.source==='object'?l.source.id:l.source,b=typeof l.target==='object'?l.target.id:l.target;return a===d.id||b===d.id;});
    var linksHtml='<strong>关联节点：</strong><br>';
    var count=0;
    cl.forEach(function(l){
        var a=typeof l.source==='object'?l.source.id:l.source,b=typeof l.target==='object'?l.target.id:l.target;
        var otherId=(a===d.id)?b:a;
        var otherNode=graphData.nodes.find(function(n){return n.id===otherId;});
        if(otherNode&&otherNode.title!==d.title){
            linksHtml+='<span class="rel-link" data-id="'+otherId+'">→ '+otherNode.title+'</span>';
            count++;
        }
    });
    document.getElementById('dLinks').innerHTML=count?linksHtml:'<span>无关联节点</span>';
    document.getElementById('detailPanel').classList.add('open');
}
function closePanel(){document.getElementById('detailPanel').classList.remove('open');}
document.getElementById('dLinks').addEventListener('click',function(e){
    var link=e.target.closest('.rel-link');
    if(link){focusNode(link.getAttribute('data-id'));}
});
function resetZoom(){d3.select('svg').transition().duration(500).call(d3.zoom().transform,d3.zoomIdentity);}
function switchView(view){
    if(view==='graph'){
        document.getElementById('graphView').style.display='block';
        document.getElementById('docView').style.display='none';
        document.getElementById('btnGraph').classList.add('active');
        document.getElementById('btnDoc').classList.remove('active');
        var svgCheck=document.querySelector('#graphView svg');
        if(!svgCheck){initGraph();}
    }else{
        document.getElementById('graphView').style.display='none';
        document.getElementById('docView').style.display='block';
        document.getElementById('btnGraph').classList.remove('active');
        document.getElementById('btnDoc').classList.add('active');
    }
}
function focusNode(nodeId){
    switchView('graph');
    setTimeout(function(){
        var nd = graphData.nodes.find(function(n){return n.id===nodeId;});
        if(nd) openPanel(nd);
    }, 300);
}
function filterDoc(q){
    q=q.toLowerCase();
    var items=document.querySelectorAll('.doc-item');
    items.forEach(function(item){item.style.display=(!q||item.textContent.toLowerCase().includes(q))?'block':'none';});
    document.querySelectorAll('.doc-section').forEach(function(sec){sec.style.display=Array.from(sec.querySelectorAll('.doc-item')).some(function(it){return it.style.display!=='none';})?'block':'none';});
}
document.addEventListener('DOMContentLoaded',initGraph);
window.addEventListener('pageshow',function(){if(document.getElementById('graphView').style.display!=='none')initGraph();});
window.addEventListener('resize',function(){var svg=document.querySelector('#graphView svg');if(svg){svg.setAttribute('width',window.innerWidth);svg.setAttribute('height',window.innerHeight);}});
</script>
</body>
</html>